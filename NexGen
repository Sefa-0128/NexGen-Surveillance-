<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>NexGen Surveillance — Securing What Matters Most</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue: #3b82f6;
      --cyan: #06b6d4;
      --indigo: #6366f1;
      --dark: #020617;
      --dark2: #0f172a;
      --dark3: #1e293b;
      --text: #f1f5f9;
      --muted: #94a3b8;
      --border: rgba(255,255,255,0.08);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--dark);
      color: var(--text);
      overflow-x: hidden;
    }

    h1, h2, h3, h4, .logo-text { font-family: 'Syne', sans-serif; }

    /* ── NAVBAR ─────────────────────────────────── */
    #navbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      transition: background .3s, backdrop-filter .3s, border-color .3s;
      border-bottom: 1px solid transparent;
    }
    #navbar.scrolled {
      background: rgba(2,6,23,0.94);
      backdrop-filter: blur(18px);
      border-color: var(--border);
    }
    .nav-inner {
      max-width: 1200px; margin: 0 auto;
      padding: 0 24px;
      display: flex; align-items: center; justify-content: space-between;
      height: 72px;
    }
    .nav-logo {
      display: flex; align-items: center; gap: 12px;
      text-decoration: none; cursor: pointer;
    }
    .logo-icon {
      width: 40px; height: 40px; border-radius: 10px;
      background: var(--blue);
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; color: #fff;
    }
    .logo-text { font-size: 18px; font-weight: 800; color: #fff; }
    .logo-text span { color: var(--blue); }

    .nav-links {
      display: flex; align-items: center; gap: 2px;
      list-style: none;
    }
    .nav-links > li { position: relative; }
    .nav-links > li > a {
      display: flex; align-items: center; gap: 5px;
      padding: 8px 16px; border-radius: 10px;
      color: var(--muted); text-decoration: none;
      font-size: 14px; font-weight: 500;
      transition: background .2s, color .2s;
      cursor: pointer;
    }
    .nav-links > li > a:hover,
    .nav-links > li > a.active { background: rgba(255,255,255,0.08); color: #fff; }
    .nav-links > li > a i.chevron {
      font-size: 11px; transition: transform .25s;
    }
    .nav-links > li:hover > a i.chevron { transform: rotate(180deg); }

    /* Dropdown */
    .dropdown {
      display: none;
      position: absolute; top: calc(100% + 8px); left: 0;
      width: 220px;
      background: rgba(2,6,23,0.97);
      backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 24px 48px rgba(0,0,0,.6);
    }
    .nav-links > li:hover .dropdown { display: block; }
    .dropdown a {
      display: flex; align-items: center; gap: 10px;
      padding: 12px 16px;
      color: var(--muted); text-decoration: none;
      font-size: 13px; transition: background .2s, color .2s;
    }
    .dropdown a i { color: var(--blue); width: 16px; }
    .dropdown a:hover { background: rgba(255,255,255,0.07); color: #fff; }

    .nav-cta {
      display: flex; align-items: center; gap: 12px;
    }
    .nav-phone {
      display: flex; align-items: center; gap: 6px;
      color: var(--muted); font-size: 13px; text-decoration: none;
      transition: color .2s;
    }
    .nav-phone:hover { color: #fff; }
    .nav-phone i { color: var(--blue); }
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 22px; border-radius: 12px;
      font-family: 'Syne', sans-serif; font-weight: 700;
      font-size: 14px; cursor: pointer; border: none;
      text-decoration: none; transition: all .25s;
    }
    .btn-primary { background: var(--blue); color: #fff; }
    .btn-primary:hover { background: #60a5fa; transform: translateY(-1px); }
    .btn-outline {
      background: transparent; color: #fff;
      border: 1px solid rgba(255,255,255,0.2);
    }
    .btn-outline:hover { background: rgba(255,255,255,0.08); }

    /* Hamburger */
    .hamburger {
      display: none; background: none; border: none;
      cursor: pointer; color: #fff; font-size: 22px;
    }
    .mobile-menu {
      display: none;
      background: rgba(2,6,23,0.98);
      border-top: 1px solid var(--border);
      padding: 12px 16px 20px;
    }
    .mobile-menu.open { display: block; }
    .mobile-link {
      display: flex; align-items: center; justify-content: space-between;
      padding: 12px 16px; border-radius: 12px;
      color: var(--muted); text-decoration: none; font-size: 14px;
      cursor: pointer; transition: background .2s, color .2s;
    }
    .mobile-link:hover { background: rgba(255,255,255,0.07); color: #fff; }
    .mobile-sub { display: none; padding-left: 16px; }
    .mobile-sub.open { display: block; }
    .mobile-sub a {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 16px; border-radius: 10px;
      color: #64748b; text-decoration: none; font-size: 13px;
      transition: color .2s;
    }
    .mobile-sub a i { color: var(--blue); }
    .mobile-sub a:hover { color: #fff; }
    .mobile-cta {
      display: flex; gap: 10px; padding: 12px 0 0;
      border-top: 1px solid var(--border); margin-top: 8px;
    }
    .mobile-cta a { flex: 1; text-align: center; justify-content: center; }

    /* ── SLIDER ─────────────────────────────────── */
    #hero {
      position: relative; min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
    }
    .slide {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      opacity: 0; transition: opacity .6s ease;
      pointer-events: none;
    }
    .slide.active { opacity: 1; pointer-events: auto; }

    .slide-bg {
      position: absolute; inset: 0;
      background-size: cover; background-position: center;
    }
    .slide[data-slide="0"] .slide-bg { background: linear-gradient(135deg, #020617 0%, #0c1a3b 50%, #0f172a 100%); }
    .slide[data-slide="1"] .slide-bg { background: linear-gradient(135deg, #020617 0%, #041f2e 50%, #0f172a 100%); }
    .slide[data-slide="2"] .slide-bg { background: linear-gradient(135deg, #020617 0%, #0e0c2e 50%, #0f172a 100%); }

    .slide-grid {
      position: absolute; inset: 0; opacity: .08;
      background-image:
        linear-gradient(var(--accent, #3b82f6) 1px, transparent 1px),
        linear-gradient(90deg, var(--accent, #3b82f6) 1px, transparent 1px);
      background-size: 60px 60px;
    }
    .slide-glow {
      position: absolute;
      top: 40%; left: 50%; transform: translate(-50%,-50%);
      width: 600px; height: 600px; border-radius: 50%;
      filter: blur(120px); opacity: .18;
      background: var(--accent, #3b82f6);
      pointer-events: none;
    }
    .slide-icon-bg {
      position: absolute; right: 5%; bottom: 10%;
      font-size: 280px; color: var(--accent, #3b82f6);
      opacity: .05; pointer-events: none;
    }

    .slide-content {
      position: relative; z-index: 2;
      text-align: center; max-width: 860px; padding: 0 24px;
    }
    .slide-badge {
      display: inline-block; margin-bottom: 24px;
      font-size: 11px; font-weight: 700; letter-spacing: .15em; text-transform: uppercase;
      padding: 7px 18px; border-radius: 100px;
      border: 1px solid; transition: opacity .5s .1s;
    }
    .slide-content h1 {
      font-size: clamp(2.4rem, 6vw, 4.5rem);
      font-weight: 800; line-height: 1.1;
      color: #fff; margin-bottom: 20px;
    }
    .slide-content p {
      font-size: 1.15rem; color: var(--muted);
      max-width: 560px; margin: 0 auto 40px; line-height: 1.7;
    }
    .slide-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

    /* Arrow controls */
    .slider-arrow {
      position: absolute; top: 50%; z-index: 10;
      transform: translateY(-50%);
      width: 48px; height: 48px; border-radius: 50%;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      color: #fff; font-size: 16px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: background .2s;
    }
    .slider-arrow:hover { background: rgba(255,255,255,0.18); }
    .slider-arrow.prev { left: 20px; }
    .slider-arrow.next { right: 20px; }

    /* Dots */
    .slider-dots {
      position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);
      display: flex; gap: 10px; z-index: 10;
    }
    .dot {
      height: 10px; border-radius: 5px;
      background: rgba(255,255,255,0.25);
      cursor: pointer; transition: width .3s, background .3s;
      width: 10px; border: none;
    }
    .dot.active { width: 32px; }

    /* ── SECTION SHARED ─────────────────────────── */
    section { padding: 96px 24px; }
    .section-label {
      font-size: 11px; font-weight: 700; letter-spacing: .18em;
      text-transform: uppercase; color: var(--blue); margin-bottom: 12px;
    }
    .section-title {
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 800; color: #fff; margin-bottom: 16px;
    }
    .section-sub {
      color: var(--muted); max-width: 520px; margin: 0 auto;
      line-height: 1.7; font-size: 1rem;
    }
    .section-head { text-align: center; margin-bottom: 64px; }

    /* ── SERVICES ───────────────────────────────── */
    #services { background: var(--dark); }
    .services-grid {
      max-width: 1100px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
    }
    .service-card {
      padding: 28px; border-radius: 20px;
      background: rgba(30,41,59,0.4);
      border: 1px solid var(--border);
      transition: background .25s, border-color .25s, transform .25s;
      cursor: pointer;
    }
    .service-card:hover {
      background: rgba(30,41,59,0.85);
      border-color: rgba(255,255,255,0.15);
      transform: translateY(-4px);
    }
    .service-icon {
      width: 48px; height: 48px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; margin-bottom: 20px;
    }
    .service-card h3 { font-size: 1.05rem; font-weight: 700; color: #fff; margin-bottom: 8px; }
    .service-card p { color: var(--muted); font-size: .9rem; line-height: 1.65; }

    /* ── SOLUTIONS ──────────────────────────────── */
    #solutions { background: var(--dark2); }
    .solutions-grid {
      max-width: 1100px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 28px;
    }
    .solution-card {
      text-align: center; padding: 48px 32px;
      border-radius: 24px;
      background: rgba(2,6,23,.5);
      border: 1px solid var(--border);
      transition: background .25s, transform .25s;
    }
    .solution-card:hover { background: rgba(2,6,23,.9); transform: translateY(-4px); }
    .solution-icon {
      width: 64px; height: 64px; border-radius: 18px;
      display: flex; align-items: center; justify-content: center;
      font-size: 26px; margin: 0 auto 24px;
    }
    .solution-card h3 { font-size: 1.2rem; font-weight: 800; color: #fff; margin-bottom: 12px; }
    .solution-card p { color: var(--muted); line-height: 1.7; font-size: .95rem; }

    /* ── ABOUT ──────────────────────────────────── */
    #about { background: var(--dark); }
    .about-grid {
      max-width: 1100px; margin: 0 auto 80px;
      display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center;
    }
    .about-text h2 { font-size: clamp(2rem,4vw,2.8rem); font-weight: 800; color: #fff; margin-bottom: 24px; }
    .about-text p { color: var(--muted); line-height: 1.75; margin-bottom: 16px; }
    .stats-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
    }
    .stat-box {
      padding: 28px 20px; border-radius: 18px;
      background: var(--dark3); border: 1px solid var(--border);
      text-align: center;
    }
    .stat-num { font-family: 'Syne', sans-serif; font-size: 2rem; font-weight: 800; color: var(--blue); }
    .stat-label { color: var(--muted); font-size: .85rem; margin-top: 4px; }

    .values-grid {
      max-width: 1100px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 24px;
    }
    .value-card {
      padding: 36px 28px; border-radius: 24px;
      background: rgba(30,41,59,0.3);
      border: 1px solid var(--border);
    }
    .value-icon {
      width: 48px; height: 48px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; margin-bottom: 20px;
    }
    .value-card h3 { font-size: 1.1rem; font-weight: 800; color: #fff; margin-bottom: 14px; }
    .value-card p { color: var(--muted); line-height: 1.7; font-size: .9rem; }
    .values-list { list-style: none; }
    .values-list li {
      display: flex; align-items: center; gap: 10px;
      color: var(--muted); font-size: .9rem; padding: 5px 0;
    }
    .values-list li::before {
      content: ''; width: 6px; height: 6px; border-radius: 50%;
      background: var(--blue); flex-shrink: 0;
    }

    /* ── CONTACT ────────────────────────────────── */
    #contact { background: var(--dark2); }
    .contact-grid {
      max-width: 1100px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1.2fr; gap: 64px; align-items: start;
    }
    .contact-info h3 { font-size: 1.6rem; font-weight: 800; color: #fff; margin-bottom: 16px; }
    .contact-info > p { color: var(--muted); line-height: 1.75; margin-bottom: 36px; }
    .contact-item {
      display: flex; align-items: flex-start; gap: 16px;
      margin-bottom: 24px; text-decoration: none;
    }
    .contact-item-icon {
      width: 48px; height: 48px; border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; flex-shrink: 0;
    }
    .contact-item-label { font-size: 11px; color: #64748b; font-weight: 600; text-transform: uppercase; letter-spacing: .1em; }
    .contact-item-val { color: #fff; font-weight: 500; font-size: .95rem; margin-top: 2px; transition: color .2s; }
    .contact-item:hover .contact-item-val { color: var(--blue); }

    /* Form */
    .form-box {
      padding: 36px; border-radius: 28px;
      background: var(--dark); border: 1px solid var(--border);
    }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-group { margin-bottom: 18px; }
    .form-group label {
      display: block; font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: .12em;
      color: var(--muted); margin-bottom: 8px;
    }
    .input-wrap { position: relative; }
    .input-wrap i {
      position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
      color: #475569; font-size: 14px; pointer-events: none;
    }
    .input-wrap.textarea-wrap i { top: 16px; transform: none; }
    .form-control {
      width: 100%; background: var(--dark2);
      border: 1px solid var(--border); border-radius: 12px;
      padding: 12px 16px 12px 40px;
      color: #fff; font-family: 'DM Sans', sans-serif; font-size: 14px;
      transition: border-color .2s, box-shadow .2s;
      outline: none; -webkit-appearance: none;
    }
    .form-control::placeholder { color: #334155; }
    .form-control:focus { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(59,130,246,.15); }
    select.form-control { padding-left: 16px; cursor: pointer; }
    select.form-control option { background: #0f172a; }
    textarea.form-control { resize: none; min-height: 120px; }

    .btn-submit {
      width: 100%; padding: 15px;
      background: var(--blue); color: #fff;
      border: none; border-radius: 14px;
      font-family: 'Syne', sans-serif; font-weight: 700; font-size: 15px;
      cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px;
      transition: background .25s, transform .2s;
    }
    .btn-submit:hover { background: #60a5fa; transform: translateY(-2px); }
    .btn-submit:disabled { opacity: .65; cursor: not-allowed; transform: none; }

    .success-box {
      display: none; flex-direction: column; align-items: center;
      justify-content: center; text-align: center; padding: 48px 24px;
    }
    .success-box.show { display: flex; }
    .success-icon {
      width: 72px; height: 72px; border-radius: 50%;
      background: rgba(16,185,129,.15);
      display: flex; align-items: center; justify-content: center;
      font-size: 32px; color: #10b981; margin-bottom: 24px;
    }
    .success-box h3 { font-size: 1.6rem; font-weight: 800; color: #fff; margin-bottom: 10px; }
    .success-box p { color: var(--muted); margin-bottom: 28px; }
    .spinner {
      width: 18px; height: 18px; border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.3);
      border-top-color: #fff;
      animation: spin .7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── FOOTER ─────────────────────────────────── */
    footer { background: var(--dark); border-top: 1px solid var(--border); }
    .footer-main {
      max-width: 1200px; margin: 0 auto;
      padding: 72px 24px 48px;
      display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px;
    }
    .footer-brand p {
      color: var(--muted); font-size: .88rem; line-height: 1.75;
      max-width: 280px; margin: 16px 0 24px;
    }
    .socials { display: flex; gap: 10px; }
    .social-btn {
      width: 36px; height: 36px; border-radius: 10px;
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      color: var(--muted); font-size: 14px; text-decoration: none;
      transition: background .2s, color .2s, border-color .2s;
    }
    .social-btn:hover { background: rgba(255,255,255,0.08); color: #fff; border-color: rgba(255,255,255,0.2); }

    .footer-col h4 {
      font-family: 'Syne', sans-serif; font-weight: 700;
      font-size: .8rem; letter-spacing: .15em; text-transform: uppercase;
      color: #fff; margin-bottom: 20px;
    }
    .footer-col ul { list-style: none; }
    .footer-col ul li { margin-bottom: 10px; }
    .footer-col ul li a {
      color: var(--muted); text-decoration: none; font-size: .88rem;
      transition: color .2s;
    }
    .footer-col ul li a:hover { color: #fff; }

    .footer-contact {
      max-width: 1200px; margin: 0 auto;
      padding: 32px 24px;
      border-top: 1px solid var(--border);
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
    }
    .fc-item { display: flex; align-items: center; gap: 14px; text-decoration: none; }
    .fc-icon {
      width: 42px; height: 42px; border-radius: 12px;
      background: rgba(59,130,246,.12);
      display: flex; align-items: center; justify-content: center;
      font-size: 17px; color: var(--blue); flex-shrink: 0;
    }
    .fc-label { font-size: 11px; color: #64748b; }
    .fc-val { color: var(--muted); font-size: .88rem; font-weight: 500; transition: color .2s; }
    .fc-item:hover .fc-val { color: #fff; }

    .footer-bottom {
      max-width: 1200px; margin: 0 auto;
      padding: 20px 24px;
      border-top: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 12px;
    }
    .footer-bottom p { color: #475569; font-size: .82rem; }
    .footer-links { display: flex; gap: 24px; }
    .footer-links a { color: #475569; text-decoration: none; font-size: .82rem; transition: color .2s; }
    .footer-links a:hover { color: #fff; }

    /* ── RESPONSIVE ─────────────────────────────── */
    @media (max-width: 900px) {
      .nav-links, .nav-cta { display: none; }
      .hamburger { display: block; }
      .about-grid { grid-template-columns: 1fr; gap: 40px; }
      .contact-grid { grid-template-columns: 1fr; gap: 40px; }
      .footer-main { grid-template-columns: 1fr 1fr; gap: 32px; }
      .footer-contact { grid-template-columns: 1fr; }
      .footer-bottom { flex-direction: column; text-align: center; }
    }
    @media (max-width: 600px) {
      section { padding: 64px 16px; }
      .form-row { grid-template-columns: 1fr; }
      .footer-main { grid-template-columns: 1fr; }
      .stats-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
<body>

<!-- ── NAVBAR ──────────────────────────────────────── -->
<nav id="navbar">
  <div class="nav-inner">
    <a class="nav-logo" href="#hero">
      <div class="logo-icon"><i class="fas fa-shield-halved"></i></div>
      <div class="logo-text">NexGen <span>Surveillance</span></div>
    </a>

    <ul class="nav-links">
      <li><a href="#hero">Home</a></li>
      <li>
        <a href="#services">Services <i class="fas fa-chevron-down chevron"></i></a>
        <div class="dropdown">
          <a href="#services"><i class="fas fa-camera"></i> CCTV Installation</a>
          <a href="#services"><i class="fas fa-desktop"></i> Remote Monitoring</a>
          <a href="#services"><i class="fas fa-lock"></i> Access Control</a>
          <a href="#services"><i class="fas fa-bell"></i> Alarm Systems</a>
          <a href="#services"><i class="fas fa-wifi"></i> Network CCTV</a>
        </div>
      </li>
      <li>
